{
    "name": "chindit/composer-check-update",
    "description": "CLI tool to view/update Composer dependencies",
    "version": "3.0.0",
    "type": "project",
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "chindit/collection": "^1.0.10",
        "symfony/console": "^7.3",
        "symfony/http-client": "^7.3",
        "composer/semver": "^3.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1.38",
        "symfony/test-pack": "^1.2",
        "symfony/maker-bundle": "^1.65",
        "pestphp/pest": "^4.3"
    },
    "license": "GPL-3.0-only",
    "authors": [
        {
            "name": "David Lumaye",
            "email": "littletiger58@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
